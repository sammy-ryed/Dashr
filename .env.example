# ═══════════════════════════════════════════════════════════════
# DASHR — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local
#
# NEVER commit .env.local to git. It is already in .gitignore.
# Set production secrets in your Vercel / CI dashboard only.
# ═══════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── App URL ───────────────────────────────────────────────────
# Used for CSRF checks, OG tags, and sitemap generation.
# In development: http://localhost:3000
# In production:  https://your-domain.com  (set this in Vercel env vars)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (Brevo Transactional API) ───────────────────────────
# Sign up at https://www.brevo.com — free tier: 300 emails/day
# Dashboard → SMTP & API → API Keys
BREVO_API_KEY=<your-brevo-api-key>
# Must be a verified sender in your Brevo account
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=DASHR

# ── Optional tuning (override defaults from lib/config.ts) ────
# EMAIL_DAILY_SOFT_LIMIT=260
# EMAIL_DASHER_MIN_COMMISSION=70
# EMAIL_DASHER_MAX_RECIPIENTS=3
# EMAIL_DASHER_COOLDOWN_MINUTES=45
